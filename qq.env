# ========== Основной бот ViaVpn ==========
# Подставьте реальные значения перед запуском.
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ADMIN_ID=TELEGRAM_ADMIN_ID

# ========== Бот поддержки ==========
SUPPORT_BOT_TOKEN=YOUR_SUPPORT_BOT_TOKEN 
SUPPORT_ADMIN_ID=SUPPORT_ADMIN_ID

# ========== 3x-ui API ==========
XUI_URL=https://DOMAIN:PANEL_PORT/WEB_PATH
XUI_API_KEY=API_KEY

# Опциональные параметры.
DOMAIN=https://YOUR_DOMAIN
MAIN_BOT_URL=https://t.me/MAIN_BOT
SUPPORT_BOT_URL=https://t.me/SUPPORT_BOT
